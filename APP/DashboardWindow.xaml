<Window x:Class="MagicKeyboardMonitor.DashboardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Dashboard" Height="140" Width="280"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        ShowInTaskbar="False" Topmost="True" ResizeMode="NoResize"
        Deactivated="Window_Deactivated">

    <Border Background="#1E2127" CornerRadius="10" Padding="15" Margin="10">
        <Border.Effect>
            <DropShadowEffect BlurRadius="10" Opacity="0.4" ShadowDepth="3" Direction="270"/>
        </Border.Effect>

        <StackPanel>
            <TextBlock x:Name="DeviceNameText" Text="Magic Keyboard" Foreground="White" FontSize="16" FontWeight="Bold"/>

            <Grid Margin="0,15,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="Battery" Foreground="#A0AAB5" FontSize="14"/>
                <TextBlock Grid.Column="2" x:Name="BatteryLevelText" Text="--%" Foreground="White" FontSize="14" FontWeight="SemiBold"/>
            </Grid>
        </StackPanel>
    </Border>
</Window>